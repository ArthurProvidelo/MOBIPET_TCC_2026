50712e.js.download" defer="" integrity="sha512-U+1s8Mjp022ITTJ/jzCV9/ZHny0QTAUrogFhLANbi1UQ10OYTMkuK17ephBC/eq8H4nIS971GBM2Cbmc1EAawA==" nonce=""></script><script defer="" src="./home-page_files/vcd15cbe7772f49c399c6a5babf22c1241717689176015" integrity="sha512-ZpsOmlRQV6y907TI0dKBHq9Md29nnaEIPlkf84rnaERnq6zvWvPUqr2ft8M1aS28oN72PdrCzSjY4U6VaAw1EQ==" nonce="" data-cf-beacon="{&quot;rayId&quot;:&quot;9e157b7d7d264b3b&quot;,&quot;serverTiming&quot;:{&quot;name&quot;:{&quot;cfExtPri&quot;:true,&quot;cfEdge&quot;:true,&quot;cfOrigin&quot;:true,&quot;cfL4&quot;:true,&quot;cfSpeedBrain&quot;:true,&quot;cfCacheStatus&quot;:true}},&quot;version&quot;:&quot;2025.9.1&quot;,&quot;token&quot;:&quot;ef88e2b2e2894e859fa7553dc8d0441c&quot;}" crossorigin="anonymous"></script>
<div id="_r_0_2" class="_pFsfA">Painel lateral</div><div id="_r_1_" class="_pFsfA">Tela</div><div id="_r_2_" class="_pFsfA">A navegação principal contém botões com opções para o documento. Para ir de um botão a outro, use as teclas de direita e esquerda. Para ativar o botão, aperte Enter. Para voltar à tela, aperte “Ctrl+F2”.</div><div class="g6DZMw"><div class="_2UyCZQ"></div><div class="_2UyCZQ"></div></div><div class="_3jkTAA"></div><div class="Bymw5Q"></div><div class="BghEng"><div></div><div></div></div><div id="_r_c_" aria-hidden="true" class="_pFsfA">Desfazer</div><div id="_r_e_" aria-hidden="true" class="_pFsfA">Refazer</div><div id="_r_g_" class="_pFsfA">O título do design contém o nome dele. Para editar o título do design, pressione a tecla Enter. Para deixar de editar o título do design, pressione a tecla ESC.</div><div id="_r_i_" aria-hidden="true" class="_pFsfA">A tela, ou editor, é onde fica seu design. Para acessar a página, aperte Enter. Para acessar os grupos ou elementos da página, aperte Enter novamente. Aperte Tab para passar para a próxima página, grupo ou elemento. Para usar a barra de ferramentas, use a tecla “Ctrl+F1”. Se um elemento estiver selecionado, você pode movê-lo usando as teclas de seta; para girar, use as teclas “,” e “.”; para redimensionar, use as teclas de seta junto com a tecla “Ctrl”. Você pode modificar os incrementos de todos esses atalhos com a tecla “Shift”.</div><div id="_r_k_" class="_pFsfA">No painel lateral, você pode aplicar modelos ou adicionar elementos. Para voltar ao editor, aperte “Ctrl+F2”.</div><div id="_r_26_" aria-hidden="true" class="_pFsfA">Adicionar página</div><div id="_r_29_" aria-hidden="true" class="_pFsfA">Adicionar tipo de página</div><div id="_r_2g_" aria-hidden="true" class="_pFsfA">Notas de apresentação</div><div id="_r_2i_" aria-hidden="true" class="_pFsfA">Mostrar temporizador</div><div id="_r_2q_" aria-hidden="true" class="_pFsfA">Zoom</div><div id="_r_2s_" aria-hidden="true" class="_pFsfA">Ocultar miniaturas das páginas</div><div id="_r_2u_" aria-hidden="true" class="_pFsfA">Ir para a página</div><div id="_r_30_" aria-hidden="true" class="_pFsfA">Visualização em grade</div><div id="_r_32_" aria-hidden="true" class="_pFsfA">Início</div><div id="_r_5p_" aria-hidden="true" class="_pFsfA">Apresentar em tela cheia</div><div id="_r_5u_" aria-hidden="true" class="_pFsfA">Assistente</div><div id="_r_67_" aria-hidden="true" class="_pFsfA">Compartilhar</div><div id="_r_66_" class="_pFsfA">Este botão abre o menu com todas as opções para compartilhar e imprimir seu design.</div><div id="_r_6i_" aria-hidden="true" class="_pFsfA">Todas as alterações foram salvas</div><div id="_r_md_" aria-hidden="true" class="_pFsfA">Apresentar em tela cheia</div><div id="_r_mf_" aria-hidden="true" class="_pFsfA">Todos os modos de apresentação</div><div id="_r_mr_" aria-hidden="true" class="_pFsfA">Animar</div><div id="_r_mt_" aria-hidden="true" class="_pFsfA">Copiar estilo</div><div id="_r_mv_" aria-hidden="true" class="_pFsfA">Comentar</div><div id="_r_n7_" aria-hidden="true" class="_pFsfA">Mais</div><span id="_r_j_-0" style="display: none;">Fundo Branco, Para começar a explorar a página, pressione Enter</span><div id="_r_q8_" aria-hidden="true" class="_pFsfA">Editar duração</div><div id="_r_qa_" aria-hidden="true" class="_pFsfA">Comentar</div></body></html>